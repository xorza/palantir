{
  "permissions": {
    "allow": [
      "WebSearch",
      "WebFetch",
      "WebFetch(*)",
      "WebFetch(domain:*)",

      "Bash(cargo fmt *)",
      "Bash(cargo clippy *)",
      "Bash(cargo test *)",

      "Bash(git mv *)",
      "Bash(git rm *)",
      "Bash(tokei*)"
    ]
  },
  "sandbox": {
    "enabled": true,
    "autoAllowBashIfSandboxed": true
  }
}
